APP_NAME="AI Summarizer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Frontend origin allowed by CORS
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=summarizer
DB_USERNAME=summarizer
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: 'database' (local) or 'sqs' (prod). No code change to switch.
QUEUE_CONNECTION=database
# When using SQS (prod) — prefer IAM task roles over static keys:
# QUEUE_CONNECTION=sqs
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/<account-id>
# SQS_QUEUE=summaries

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- LLM (provider-agnostic client) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=          # from console.anthropic.com (NOT a claude.ai Pro account)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Optional free-tier fallback adapter (not implemented in MVP):
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Guardrails (cost + SSRF) ---
MAX_INPUT_TOKENS=12000
RATE_LIMIT_PER_HOUR=20
FETCH_TIMEOUT_SECONDS=10
FETCH_MAX_BYTES=2000000
FETCH_MAX_REDIRECTS=3
